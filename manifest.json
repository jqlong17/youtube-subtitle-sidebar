{
  "manifest_version": 3,
  "name": "YouTube 字幕侧栏",
  "version": "1.0.0",
  "description": "在 YouTube 视频右侧显示可解析的字幕内容。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.googlevideo.com/*",
    "https://*.youtube.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js",
        "transcript-trigger.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}
